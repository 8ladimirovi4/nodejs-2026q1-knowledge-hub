PORT=4000
ADMINER_PORT=8080

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL="postgresql://admin:admin@localhost:5432/knowledge_hub?schema=public"

CRYPT_SALT=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=15m
TOKEN_REFRESH_EXPIRE_TIME=7d

AUTH_THROTTLE_TTL_MS=60000

# please note, enough requests for rbac tests
AUTH_THROTTLE_LIMIT=100

# Human-readable console logs. Use `npm run start:prod` to set NODE_ENV=production (structured JSON).

LOG_LEVEL=log
LOG_MAX_FILE_SIZE=1024
LOG_DIR=logs

#AI
#gemini-2.0-flash have 0 limit requests for free license. It's better to use gemini-2.5 and higer. For example 
#gemini-2.5-flash-lite
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.0-flash
AI_RATE_LIMIT_RPM=20
AI_CACHE_TTL_SEC=300

# Generic /ai/generate conversation memory (in-process, cleared on idle read).
AI_CONVERSATION_MAX_PAIRS=10
# Seconds without a message on this thread before turns are discarded on next access.
AI_CONVERSATION_IDLE_TTL_SEC=2000
# HTTP timeout for Gemini generateContent (milliseconds).
# If not used Default 120000
GEMINI_HTTP_TIMEOUT_MS=120000
#actual embedding version is gemini-embedding-2
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
RAG_VECTOR_DB_PROVIDER=qdrant
RAG_VECTOR_DB_URL=http://vectordb:6333
RAG_VECTOR_COLLECTION=knowledge_hub_articles
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_CONVERSATION_MAX_MESSAGES=20
RAG_CHAT_RETRIEVAL_LIMIT=5
RAG_EMBEDDING_VECTOR_SIZE=3072
QUADRANT_PORT=6333